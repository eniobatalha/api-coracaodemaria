# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=troque-por-uma-chave-secreta-forte

# ── Banco de dados (deve bater com o docker-compose.yml) ──────────────────────
POSTGRES_DB=coracaodemaria
POSTGRES_USER=cma_user
POSTGRES_PASSWORD=cma_pass_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql://cma_user:cma_pass_dev@localhost:5432/coracaodemaria

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=troque-por-uma-chave-jwt-forte
JWT_EXPIRES_HOURS=1

# ── E-mail (SMTP) ─────────────────────────────────────────────────────────────
# Em desenvolvimento, os e-mails são apenas logados no console (não enviados).
# Configure o SMTP real apenas em produção.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@coracaodemaria.edu.br
MAIL_SUPPRESS_SEND=true

# ── Frontend (usado nos links dos e-mails) ────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Expiração de tokens de e-mail ─────────────────────────────────────────────
TOKEN_CONFIRMACAO_EXPIRACAO_HORAS=48
TOKEN_RESET_SENHA_EXPIRACAO_HORAS=2
